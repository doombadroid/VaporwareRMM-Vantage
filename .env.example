# VaporwareRMM Vantage — environment template.
# Copy to .env and fill in the __GENERATE_ME__ values. Vantage
# refuses to boot if any sentinel is left in place.

# --- Required secrets -------------------------------------------------

# Postgres password for the Vantage service account. Generated once.
POSTGRES_PASSWORD=__GENERATE_ME__

# JWT signing key. Must be >= 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=__GENERATE_ME__

# AES-256-GCM key for the encrypted-secrets column path. 32 bytes
# base64-encoded. Generate with:
#   openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=__GENERATE_ME__

# First-run admin password. Must satisfy complexity (>=12 chars,
# upper + lower + digit + special). If you leave this unset on
# first run, Vantage generates a password and prints it ONCE to
# stdout — copy it to your password manager.
ADMIN_PASSWORD=__GENERATE_ME__

# External URL Edges reach Vantage at. Embedded in enrollment
# bundles and used by the cookie-secure sanity check. Must have
# scheme + host. Must be https:// unless FORCE_SECURE_COOKIES=false
# (dev-only opt-out). Vantage refuses to start on invalid values.
VANTAGE_PUBLIC_URL=__GENERATE_ME__

# --- Optional ---------------------------------------------------------

# CORS allowlist (comma-separated origins). Empty = block all
# cross-origin browser requests. Set when running the dashboard
# on a different origin from Vantage in dev.
# CORS_ORIGINS=http://localhost:3001

# Caddy hostname. localhost in dev; your real domain in production
# (Caddy auto-issues a Let's Encrypt cert for the domain).
DOMAIN=localhost

# Let's Encrypt contact email.
# ACME_EMAIL=ops@example.com

# Caddy bind address. 127.0.0.1 keeps Caddy local-only (good for
# Tailscale-tunneled access). 0.0.0.0 binds publicly.
BIND_ADDR=127.0.0.1
