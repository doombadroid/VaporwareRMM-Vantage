{
  "name": "vaporrmm-vantage",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "VaporwareRMM Vantage - Federation control server",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "build:dashboard": "turbo run build --filter=@vaporrmm-vantage/dashboard",
    "dev:dashboard": "turbo run dev --filter=@vaporrmm-vantage/dashboard",
    "dev:vantage": "cd packages/vantage && go run main.go",
    "build:vantage": "cd packages/vantage && go build -o ../../bin/vantage main.go",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:go": "go test ./packages/..."
  },
  "devDependencies": {
    "@turbo/gen": "^2.3.3",
    "prettier": "^3.4.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.2",
      "brace-expansion@5": "^5.0.5",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "postcss": "^8.5.10"
    }
  }
}
